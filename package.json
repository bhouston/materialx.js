{
  "name": "materialx.js",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript MaterialX monorepo",
  "type": "module",
  "scripts": {
    "build": "tsgo -b && pnpm -r build",
    "release:package": "node ./scripts/src/make-release.ts",
    "release:all": "node ./scripts/src/make-release-all.ts",
    "dev": "pnpm -r --parallel --stream dev",
    "cli": "pnpm --filter @materialx-js/materialx-cli start",
    "viewer:dev": "pnpm --filter viewer dev",
    "viewer:build": "pnpm --filter viewer build",
    "viewer:test": "pnpm --filter viewer test",
    "generate:nodes": "pnpm --filter @materialx-js/materialx build && pnpm --filter @materialx-js/materialx generate:nodes",
    "clean": "rimraf dist packages/**/dist packages/**/.tsbuildinfo",
    "clean:all": "pnpm clean && rimraf node_modules packages/**/node_modules",
    "format": "oxfmt .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "tsc": "tsgo -b",
    "tsgo": "tsgo -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "rimraf": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@typescript/native-preview": "7.0.0-dev.20251229.1",
    "@vitest/coverage-v8": "^4.0.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.56.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
