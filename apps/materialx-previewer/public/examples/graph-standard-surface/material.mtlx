<?xml version="1.0"?>
<materialx version="1.39" colorspace="lin_rec709">
  <nodegraph name="NG_Preview">
    <image name="mask_tex" type="float">
      <input name="file" type="filename" value="mask.svg" />
    </image>
    <mix name="node_mix_8" type="color3">
      <input name="fg" type="color3" value="0.8, 0.2, 0.08" />
      <input name="bg" type="color3" value="0.1, 0.08, 0.06" />
      <input name="mix" type="float" nodename="mask_tex" />
    </mix>
    <output name="base_color_output" type="color3" nodename="node_mix_8" />
  </nodegraph>
  <standard_surface name="N_StandardSurface" type="surfaceshader">
    <input name="base_color" type="color3" nodegraph="NG_Preview" output="base_color_output" />
    <input name="specular_roughness" type="float" value="0.28" />
  </standard_surface>
  <surfacematerial name="M_Preview" type="material">
    <input name="surfaceshader" type="surfaceshader" nodename="N_StandardSurface" />
  </surfacematerial>
</materialx>
