{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "plugins": ["eslint", "typescript", "oxc", "unicorn"],
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/*.spec.ts"],
      "plugins": ["eslint", "typescript", "oxc", "unicorn", "vitest"]
    }
  ]
}
