<?xml version="1.0"?>
<materialx version="1.39" colorspace="lin_rec709">
  <nodegraph name="NG_Simple">
    <image name="base_tex" type="color3">
      <input name="file" type="filename" value="swatch.svg" />
    </image>
    <output name="base_color_out" type="color3" nodename="base_tex" />
  </nodegraph>
  <standard_surface name="SR_Simple" type="surfaceshader">
    <input name="base_color" type="color3" nodegraph="NG_Simple" output="base_color_out" />
    <input name="specular_roughness" type="float" value="0.32" />
    <input name="metalness" type="float" value="0.1" />
  </standard_surface>
  <surfacematerial name="M_Simple" type="material">
    <input name="surfaceshader" type="surfaceshader" nodename="SR_Simple" />
  </surfacematerial>
</materialx>
